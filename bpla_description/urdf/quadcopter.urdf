<?xml version="1.0"?>
<robot name="quadcopter" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ====== МАТЕРИАЛЫ ====== -->
  <material name="black">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="gray">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>

  <!-- ====== БАЗОВАЯ СИСТЕМА КООРДИНАТ (корпус) ====== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.2 0.2 0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.2 0.2 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.02"/>
    </inertial>
  </link>

  <!-- ====== ЛУЧИ ====== -->
  <!-- Макрос для луча: name, x, y, z, rotation_z -->
  
  <!-- Луч 1 (передний правый) -->
  <link name="arm_1">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.3"/>
      </geometry>
      <origin xyz="0.15 0 0" rpy="0 1.5708 0"/>
      <material name="black"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="arm_1_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_1"/>
    <origin xyz="0.1 0.1 0" rpy="0 0 0.7854"/>
  </joint>

  <!-- Луч 2 (передний левый) -->
  <link name="arm_2">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.3"/>
      </geometry>
      <origin xyz="0.15 0 0" rpy="0 1.5708 0"/>
      <material name="black"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="arm_2_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_2"/>
    <origin xyz="-0.1 0.1 0" rpy="0 0 2.3562"/>
  </joint>

  <!-- Луч 3 (задний левый) -->
  <link name="arm_3">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.3"/>
      </geometry>
      <origin xyz="0.15 0 0" rpy="0 1.5708 0"/>
      <material name="black"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="arm_3_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_3"/>
    <origin xyz="-0.1 -0.1 0" rpy="0 0 -2.3562"/>
  </joint>

  <!-- Луч 4 (задний правый) -->
  <link name="arm_4">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.3"/>
      </geometry>
      <origin xyz="0.15 0 0" rpy="0 1.5708 0"/>
      <material name="black"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="arm_4_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_4"/>
    <origin xyz="0.1 -0.1 0" rpy="0 0 -0.7854"/>
  </joint>

  <!-- ====== МОТОРЫ (4 шт, на концах лучей) ====== -->
  
  <!-- Мотор 1 -->
  <link name="motor_1">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="motor_1_joint" type="fixed">
    <parent link="arm_1"/>
    <child link="motor_1"/>
    <origin xyz="0.3 0 0.04" rpy="0 0 0"/>
  </joint>

  <!-- Мотор 2 -->
  <link name="motor_2">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="motor_2_joint" type="fixed">
    <parent link="arm_2"/>
    <child link="motor_2"/>
    <origin xyz="0.3 0 0.04" rpy="0 0 0"/>
  </joint>

  <!-- Мотор 3 -->
  <link name="motor_3">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="motor_3_joint" type="fixed">
    <parent link="arm_3"/>
    <child link="motor_3"/>
    <origin xyz="0.3 0 0.04" rpy="0 0 0"/>
  </joint>

  <!-- Мотор 4 -->
  <link name="motor_4">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="motor_4_joint" type="fixed">
    <parent link="arm_4"/>
    <child link="motor_4"/>
    <origin xyz="0.3 0 0.04" rpy="0 0 0"/>
  </joint>

  <!-- ====== ПРОПЕЛЛЕРЫ (вращающиеся) ====== -->
  
  <!-- Пропеллер 1 -->
  <link name="prop_1">
    <visual>
      <geometry>
        <box size="0.25 0.03 0.005"/>
      </geometry>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="prop_1_joint" type="continuous">
    <parent link="motor_1"/>
    <child link="prop_1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Пропеллер 2 -->
  <link name="prop_2">
    <visual>
      <geometry>
        <box size="0.25 0.03 0.005"/>
      </geometry>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="prop_2_joint" type="continuous">
    <parent link="motor_2"/>
    <child link="prop_2"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Пропеллер 3 -->
  <link name="prop_3">
    <visual>
      <geometry>
        <box size="0.25 0.03 0.005"/>
      </geometry>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="prop_3_joint" type="continuous">
    <parent link="motor_3"/>
    <child link="prop_3"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Пропеллер 4 -->
  <link name="prop_4">
    <visual>
      <geometry>
        <box size="0.25 0.03 0.005"/>
      </geometry>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="prop_4_joint" type="continuous">
    <parent link="motor_4"/>
    <child link="prop_4"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

</robot>
